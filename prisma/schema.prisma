generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  IT_STAFF
  REQUESTER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  UNRESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetCategory {
  COMPUTER
  LAPTOP
  MONITOR
  KEYBOARD
  MOUSE
  PRINTER
  PHONE
  TABLET
  NETWORK
  SERVER
  UPS
  OTHER
}

enum AssetStatus {
  ACTIVE
  ASSIGNED
  IN_SERVICE
  SCRAP
  RETIRED
}

enum ServiceType {
  REPAIR
  MAINTENANCE
  WARRANTY
}

enum ServiceStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String?
  role       Role     @default(REQUESTER)
  department String?
  phone      String?
  isActive    Boolean  @default(true)
  permissions String[] @default([])
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedTickets  Ticket[]         @relation("AssignedTo")
  requestedTickets Ticket[]         @relation("RequestedBy")
  ticketActivities TicketActivity[]
  ticketComments   TicketComment[]
  assetAssignments AssetAssignment[]
  slaBreaches      SLABreach[]
}

model Ticket {
  id           String       @id @default(cuid())
  ticketNumber String       @unique
  title        String
  description  String       @db.Text
  status       TicketStatus @default(OPEN)
  priority     Priority     @default(MEDIUM)
  category     String?

  requesterId String
  requester   User   @relation("RequestedBy", fields: [requesterId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id])

  emailMessageId String?  @unique
  emailFrom      String?
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  slaDeadline DateTime?
  slaBreach   Boolean   @default(false)

  resolvedAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  activities  TicketActivity[]
  comments    TicketComment[]
  slaBreaches SLABreach[]

  @@index([requesterId])
  @@index([assignedToId])
  @@index([status])
  @@index([slaBreach, slaDeadline])
  @@index([companyId])
}

model TicketActivity {
  id        String       @id @default(cuid())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  action    String
  oldStatus TicketStatus?
  newStatus TicketStatus?
  notes     String?      @db.Text
  createdAt DateTime     @default(now())

  @@index([ticketId])
  @@index([userId])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ticketId])
  @@index([authorId])
}

model SLAConfig {
  id             String   @id @default(cuid())
  priority       Priority @unique
  responseHours  Int
  resolutionHours Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SLABreach {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  breachType   String
  breachedAt   DateTime @default(now())

  @@unique([ticketId, breachType])
  @@index([ticketId])
  @@index([assignedToId])
}

model Asset {
  id             String        @id @default(cuid())
  assetCode      String        @unique
  name           String
  description    String?
  category       AssetCategory
  brand          String?
  model          String?
  serialNumber   String?
  purchaseDate   DateTime?
  purchasePrice  Decimal?      @db.Decimal(10, 2)
  warrantyExpiry DateTime?
  status         AssetStatus   @default(ACTIVE)
  location       String?
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  assignments AssetAssignment[]
  services    AssetService[]
  tickets     Ticket[]
}

model AssetAssignment {
  id         String    @id @default(cuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?
  isActive   Boolean   @default(true)

  @@index([assetId])
  @@index([userId])
}

model AssetService {
  id          String        @id @default(cuid())
  assetId     String
  asset       Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type        ServiceType
  description String        @db.Text
  cost        Decimal?      @db.Decimal(10, 2)
  vendor      String?
  startDate   DateTime      @default(now())
  endDate     DateTime?
  status      ServiceStatus @default(IN_PROGRESS)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([assetId])
}

model Company {
  id           String   @id @default(cuid())
  name         String
  shortCode    String   @unique
  emailDomains String[] @default([])
  address      String?
  phone        String?
  website      String?
  isActive     Boolean  @default(true)
  contactName  String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users   User[]
  tickets Ticket[]
}

model EmailConfig {
  id           String   @id @default(cuid())
  isActive     Boolean  @default(false)
  provider     String   @default("MICROSOFT_GRAPH") // "IMAP" | "MICROSOFT_GRAPH"
  // Microsoft Graph alanları
  tenantId     String?
  clientId     String?
  clientSecret String?
  mailbox      String?
  // IMAP alanları
  imapHost       String?
  imapPort       Int?
  imapUser       String?
  imapPassword   String?
  allowedSenders String  @default("") // newline-separated list of emails or @domain.com patterns
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
