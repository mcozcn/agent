generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  IT_STAFF
  REQUESTER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  UNRESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetCategory {
  COMPUTER
  LAPTOP
  MONITOR
  KEYBOARD
  MOUSE
  PRINTER
  PHONE
  TABLET
  NETWORK
  SERVER
  UPS
  OTHER
}

enum AssetStatus {
  ACTIVE
  ASSIGNED
  IN_SERVICE
  SCRAP
  RETIRED
}

enum ServiceType {
  REPAIR
  MAINTENANCE
  WARRANTY
}

enum ServiceStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  password   String?
  role       Role     @default(REQUESTER)
  department String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assignedTickets  Ticket[]         @relation("AssignedTo")
  requestedTickets Ticket[]         @relation("RequestedBy")
  ticketActivities TicketActivity[]
  ticketComments   TicketComment[]
  assetAssignments AssetAssignment[]
  slaBreaches      SLABreach[]
}

model Ticket {
  id           String       @id @default(cuid())
  ticketNumber String       @unique
  title        String
  description  String       @db.Text
  status       TicketStatus @default(OPEN)
  priority     Priority     @default(MEDIUM)
  category     String?

  requesterId String
  requester   User   @relation("RequestedBy", fields: [requesterId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTo", fields: [assignedToId], references: [id])

  emailMessageId String?
  emailFrom      String?

  slaDeadline DateTime?
  slaBreach   Boolean   @default(false)

  resolvedAt DateTime?
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  activities  TicketActivity[]
  comments    TicketComment[]
  slaBreaches SLABreach[]
}

model TicketActivity {
  id        String       @id @default(cuid())
  ticketId  String
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  action    String
  oldStatus TicketStatus?
  newStatus TicketStatus?
  notes     String?      @db.Text
  createdAt DateTime     @default(now())
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SLAConfig {
  id             String   @id @default(cuid())
  priority       Priority @unique
  responseHours  Int
  resolutionHours Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SLABreach {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?    @relation(fields: [assignedToId], references: [id])
  breachType   String
  breachedAt   DateTime @default(now())
}

model Asset {
  id             String        @id @default(cuid())
  assetCode      String        @unique
  name           String
  description    String?
  category       AssetCategory
  brand          String?
  model          String?
  serialNumber   String?
  purchaseDate   DateTime?
  purchasePrice  Decimal?      @db.Decimal(10, 2)
  warrantyExpiry DateTime?
  status         AssetStatus   @default(ACTIVE)
  location       String?
  notes          String?       @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  assignments AssetAssignment[]
  services    AssetService[]
}

model AssetAssignment {
  id         String    @id @default(cuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  assignedAt DateTime  @default(now())
  returnedAt DateTime?
  notes      String?
  isActive   Boolean   @default(true)
}

model AssetService {
  id          String        @id @default(cuid())
  assetId     String
  asset       Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type        ServiceType
  description String        @db.Text
  cost        Decimal?      @db.Decimal(10, 2)
  vendor      String?
  startDate   DateTime      @default(now())
  endDate     DateTime?
  status      ServiceStatus @default(IN_PROGRESS)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model EmailConfig {
  id           String   @id @default(cuid())
  isActive     Boolean  @default(false)
  provider     String   @default("MICROSOFT_GRAPH") // "IMAP" | "MICROSOFT_GRAPH"
  // Microsoft Graph alanları
  tenantId     String?
  clientId     String?
  clientSecret String?
  mailbox      String?
  // IMAP alanları
  imapHost     String?
  imapPort     Int?
  imapUser     String?
  imapPassword String?
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
